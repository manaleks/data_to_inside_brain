# data_to_inside_brain — env template (variant B, web-only).
#
# Copy to .env and fill in. .env must be gitignored.
#
# Variant B = Claude Code subscription only. No OpenRouter API key.
# See README.md fork-notice and ouroboros/llm.py header for details.

# ============================================================================
# GitHub — где живёт brain'овский target repo (он же product repo)
# ============================================================================

# Username под которым brain коммитит. Должен совпадать с тем под кем
# выполнен `gh auth login`.
GITHUB_USER=manaleks

# Target repo — куда brain коммитит свои дельты. ВАЖНО: это product repo
# data_to_inside, не сам brain. Branch `ouroboros` будет создан в нём.
GITHUB_REPO=data_to_inside

# Personal access token с scope `repo` (для push в target). Если работаешь
# через `gh auth login` — этот токен можно получить через
# `gh auth token`.
GITHUB_TOKEN=

# ============================================================================
# Models — Claude only (variant B). Non-Anthropic ids fall back с warning.
# ============================================================================

# Primary thinking model. Можно поменять на claude-sonnet-4-5 для дешевле.
OUROBOROS_MODEL=claude-opus-4-7

# Code editing tasks (через `claude` CLI tool). Обычно совпадает с primary.
OUROBOROS_MODEL_CODE=claude-opus-4-7

# Lightweight tasks (consciousness, dedup, compaction). claude-haiku-4-5 если есть.
OUROBOROS_MODEL_LIGHT=claude-haiku-4-5

# ============================================================================
# Operations
# ============================================================================

# How many parallel worker processes. Web-only mode → 1 хватит.
OUROBOROS_MAX_WORKERS=1

# Max LLM rounds per single task before forced summary.
OUROBOROS_MAX_ROUNDS=200

# Background consciousness budget (% of TOTAL_BUDGET). На subscription
# не критично; держим лимит чтобы не зацикливался.
OUROBOROS_BG_BUDGET_PCT=10

# Total budget in USD. На subscription это виртуальный лимит; используется
# как guard rail на «зацикленность» (если бюджет иссяк — остановить).
TOTAL_BUDGET=10

# ============================================================================
# Product hook (Sprint 6.6)
# ============================================================================

# URL продукта (FastAPI exec_demo). Brain делает HTTP requests на эти
# endpoints для чтения journal/bugs/proposals и записи observations.
OUROBOROS_PRODUCT_API=http://127.0.0.1:8765

# Login для product API (создан через `core.auth.create_user` в product).
# Brain использует эту учётку чтобы аутентифицироваться при вызове.
OUROBOROS_PRODUCT_USER=brain@local
OUROBOROS_PRODUCT_PASSWORD=

# ============================================================================
# Variant B specific (legacy keys not used)
# ============================================================================

# Brain code reads OPENROUTER_API_KEY in supervisor/state.py — мы не
# используем OpenRouter, но кладём dummy чтобы не падать на вход в
# missing env. Будет рефакторено в Sprint 6.5.x.
OPENROUTER_API_KEY=not-used-variant-b-claude-subscription
